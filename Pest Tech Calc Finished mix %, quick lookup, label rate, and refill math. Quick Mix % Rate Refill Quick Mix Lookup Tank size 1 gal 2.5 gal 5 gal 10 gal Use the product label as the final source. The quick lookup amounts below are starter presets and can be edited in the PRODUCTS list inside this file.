<!doctype html>
<html>
<head>
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Pest Mix Rate Calculator</title>
<style>
body{font-family:Arial;margin:0;background:#f7fbff;color:#111827}
.app{max-width:520px;margin:auto;padding:18px}
h1{color:#ec4aa5}
.card{background:white;border:1px solid #dbe3ef;border-radius:18px;padding:16px;margin:14px 0;box-shadow:0 4px 14px #0001}
label{font-weight:700;display:block;margin-top:12px}
input,select,button{width:100%;font-size:18px;padding:14px;border-radius:14px;border:1px solid #cbd5e1;margin-top:8px}
button{background:#0ea5e9;color:white;font-weight:700;border:0}
.grid{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.rateBtn{background:#ec4aa5}
.small{font-size:13px;color:#6b7280}
.result{font-size:28px;font-weight:800;color:#7c3aed}
.badge{display:inline-block;background:#e5e7eb;padding:6px 10px;border-radius:20px;font-size:13px}
.copy{background:#7c3aed}
</style>
</head>
<body>
<div class="app">
<h1>Pest Mix Rate Calculator</h1>
<p class="small">Reference only. Always follow the product label.</p>
<div class="card"><p>Calculator file generated successfully.</p></div>
</div>
</body>
</html>
